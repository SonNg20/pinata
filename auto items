-- Tính năng thu nhỏ UI
local minimized = false
MinButton.MouseButton1Click:Connect(function()
    minimized = not minimized
    if minimized then
        Container.Visible = false
        MainFrame.Size = UDim2.new(0, 220, 0, 35)
        MinButton.Text = "+"
    else
        Container.Visible = true
        MainFrame.Size = UDim2.new(0, 220, 0, 280)
        MinButton.Text = "-"
    end
end)

-- Biến trạng thái On/Off
local states = {
    TNT = false,
    Sprinkler = false,
    PartyBox = false,
    Gift1 = false,
    Gift2 = false
}

-- Hàm tạo các nút Toggle
local function createToggle(name, stateKey)
    local Button = Instance.new("TextButton")
    Button.Parent = Container
    Button.Size = UDim2.new(1, -10, 0, 40)
    Button.Position = UDim2.new(0, 5, 0, 0)
    Button.BackgroundColor3 = Color3.fromRGB(150, 50, 50)
    Button.Text = name .. ": OFF"
    Button.TextColor3 = Color3.fromRGB(255, 255, 255)
    Button.Font = Enum.Font.SourceSansSemibold
    Button.TextSize = 16

    Button.MouseButton1Click:Connect(function()
        states[stateKey] = not states[stateKey]
        if states[stateKey] then
            Button.BackgroundColor3 = Color3.fromRGB(50, 150, 50)
            Button.Text = name .. ": ON"
        else
            Button.BackgroundColor3 = Color3.fromRGB(150, 50, 50)
            Button.Text = name .. ": OFF"
        end
    end)
end

-- Tạo các nút bấm trên UI
createToggle("TNT Crate (10s)", "TNT")
createToggle("Sprinkler (303s)", "Sprinkler")
createToggle("Party Box (15s)", "PartyBox")
createToggle("Craft Gift 1 (5s)", "Gift1")
createToggle("Craft Gift 2 (5s)", "Gift2")

