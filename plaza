local function getWebRAP(itemId, itemClass, isGold, isShiny, isRainbow, tierLevel)
	if #RAPWebCache == 0 then return 0 end
	for _, itemData in ipairs(RAPWebCache) do
		if itemData.category == itemClass and itemData.configData and itemData.configData.id == itemId then
			local config = itemData.configData
			local match = true
			if itemClass == "Pet" then
				if isGold and config.pt ~= 1 then match = false
				elseif isRainbow and config.pt ~= 2 then match = false
				elseif not isGold and not isRainbow and config.pt ~= nil then match = false end
				if isShiny and config.sh ~= true then match = false
				elseif not isShiny and config.sh == true then match = false end
			end
			if (itemClass == "Enchant" or itemClass == "Potion") and tierLevel and config.tn ~= tierLevel then match = false end
			if match then return tonumber(itemData.value) or 0 end
		end
	end
	return 0
end

local function parseRarityName(rarityProp)
	if not rarityProp then return nil end
	if type(rarityProp) == "table" then return rarityProp.DisplayName or rarityProp.Name or rarityProp.id or "Special" end
	return tostring(rarityProp)
end

