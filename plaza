				elseif itemClass:lower():find("enchant") or itemClass:lower():find("book") then itemClass = "Enchant"
				elseif itemClass:lower():find("potion") then itemClass = "Potion"
				elseif itemClass:lower():find("charm") then itemClass = "Charm"
				elseif itemClass:lower():find("lootbox") then itemClass = "Lootbox"
				else itemClass = "Misc" end

				if itemClass == "Pet" then
					local lowName = realName:lower()
					if string.find(lowName, "huge") then itemRarity = "Huge"
					elseif string.find(lowName, "titanic") then itemRarity = "Titanic"
					elseif string.find(lowName, "gargantuan") then itemRarity = "Gargantuan" end
					
					if itemSlot and (itemSlot:FindFirstChild("Gold") or itemSlot:FindFirstChild("GoldPulse")) or string.find(lowName, "gold") then isGoldPet = true end
					if itemSlot and (itemSlot:FindFirstChild("ShinePulse") or itemSlot:FindFirstChild("Shiny")) or string.find(lowName, "shiny") then isShinyPet = true end
				end

				if itemSlot and itemSlot:FindFirstChild("Quantity") then
					amountInt = tonumber((itemSlot.Quantity.Text:gsub("%D", ""))) or 1
				end
				if itemObj:FindFirstChild("Buy") and itemObj.Buy:FindFirstChild("Cost") then
					priceInt = parseShortenedNumber(itemObj.Buy.Cost.Text)
				end

				local actualItemUID = nil
				local rawDataAttribute = itemObj:GetAttribute("Data") or itemObj:GetAttribute("ItemData") or itemObj:GetAttribute("Item")
				
				if rawDataAttribute then
					local decodedAttr = type(rawDataAttribute) == "string" and Library.JSONDecode(rawDataAttribute) or rawDataAttribute
					if decodedAttr then
						actualItemUID = decodedAttr.uid or decodedAttr._id or (decodedAttr.data and decodedAttr.data.uid) or (decodedAttr.ItemData and decodedAttr.ItemData.uid)
					end
				end

				if not actualItemUID or actualItemUID == "" or string.len(tostring(actualItemUID)) < 5 then
					pcall(function()
						local boothData = Library.Booths and Library.Booths.GetBoothData and Library.Booths.GetBoothData(tonumber(ownerID))
						if boothData and boothData.Listings then
							for uid, details in pairs(boothData.Listings) do
								if details.ItemData and (tostring(details.ItemData.id):lower() == string.lower(realName) or tostring(details.ItemData._id):lower() == string.lower(realName)) then
									actualItemUID = uid
									break
								end
							end
						end
					end)
				end
				
				if not actualItemUID or actualItemUID == "" then actualItemUID = itemObj.Name end

				local webQueryId = attrId or realName
				if (itemClass == "Enchant" or itemClass == "Potion") and realName ~= "Coins" then
					webQueryId = realName:gsub("%s+[IVXLCDM]+$", ""):gsub("%s+%d+$", "")
				end
				
				local rapPrice = getWebRAP(webQueryId, itemClass, isGoldPet, isShinyPet, isRainbowPet, tierLevel)

				local shouldBuy = false
				
				local targetConfig = getgenv().SniperConfig["Target"]
				if targetConfig and targetConfig.Enabled then
					for _, rule in ipairs(targetConfig) do
						if string.lower(realName) == string.lower(rule[1]) or string.lower(itemObj.Name) == string.lower(rule[1]) then
							local maxAllowedPrice = parseConfigNumber(rule.MaxPrice)
							if priceInt <= maxAllowedPrice then shouldBuy = true end
							break
						end
					end
				end

				if not shouldBuy then
					local cfgGroup = getgenv().SniperConfig[itemClass]
					if cfgGroup and cfgGroup.Enabled and rapPrice > 0 then
						local discount = math.round((1 - (priceInt / rapPrice)) * 100)
						
						if itemClass == "Pet" then
							local targetKey = nil
							if itemRarity == "Huge" then targetKey = "All Huges"
							elseif itemRarity == "Titanic" then targetKey = "All Titanics"
							elseif itemRarity == "Gargantuan" then targetKey = "All Gargantuans" end
							
							if targetKey then
								for _, rule in ipairs(cfgGroup) do
									if rule[1] == targetKey then
										local maxAllowedPrice = parseConfigNumber(rule.MaxPrice)
										local targetDiscount = parsePercent(rule.PercentOffRap)
										
										local variantAllowed = true
										if isGoldPet and not rule.AllowGolden then variantAllowed = false end
										if isRainbowPet and not rule.AllowRainbow then variantAllowed = false end
										if isShinyPet and not rule.AllowShiny then variantAllowed = false end
										
										if priceInt <= maxAllowedPrice and discount >= targetDiscount and variantAllowed then
											shouldBuy = true
										end
										break
									end
								end
							end
							
						elseif itemClass == "Enchant" and matchedFromHardList and itemRarity == "Exclusive" then
							for _, rule in ipairs(cfgGroup) do
								if rule[1] == "All Exclusives" then
									local maxAllowedPrice = parseConfigNumber(rule.MaxPrice)
									local targetDiscount = parsePercent(rule.PercentOffRap)
									
									if priceInt <= maxAllowedPrice and discount >= targetDiscount then
										shouldBuy = true
									end
									break
								end
							end
						end
					end
				end

				if shouldBuy then
					local myCurrentGems = getCurrentGems()
					local maxTotalPrice = priceInt * amountInt
					local finalPurchaseQuantity = amountInt

					if myCurrentGems < maxTotalPrice then
						finalPurchaseQuantity = math.floor(myCurrentGems / priceInt)
					end

					if finalPurchaseQuantity > 0 then
						local actualCost = priceInt * finalPurchaseQuantity
						local totalRapValue = rapPrice * finalPurchaseQuantity
						local cleanName = realName:gsub("%s+[IVXLCDM]+$", ""):gsub("%s+%d+$", ""):gsub("%s+[Ee]nchant$", ""):gsub("%s+[Bb]ook$", ""):match("^%s*(.-)%s*$")
						
						local purchaseArgs = {
							[1] = tonumber(ownerID),
							[2] = {[tostring(actualItemUID)] = tonumber(finalPurchaseQuantity)},
							[3] = {
								["Caller"] = {
									["LineNumber"] = 527,
									["ParameterCount"] = 2,
									["Variadic"] = false,
									["Traceback"] = "ReplicatedStorage.Library.Client.BoothCmds:527 function PromptPurchase2\nReplicatedStorage.Library.Client.BoothCmds:654 function promptOtherPlayerBooth2\nReplicatedStorage.Library.Client.BoothCmds:157",
									["ScriptPath"] = "ReplicatedStorage.Library.Client.BoothCmds",
									["ScriptClass"] = "ModuleScript",
									["Handle"] = "function: 0xf9cb588e6fd282be", 
									["FunctionName"] = "PromptPurchase2",
									["ScriptType"] = "Instance",
									["SourceIdentifier"] = "ReplicatedStorage.Library.Client.BoothCmds"
								}
							}
						}
						
						local buySuccess, buyResult = pcall(function()
							return PurchaseRemote:InvokeServer(unpack(purchaseArgs))
						end)
						
						if buySuccess then
							print(string.format("✅ Thành công mua được x%d %s!", finalPurchaseQuantity, cleanName))
							HasPurchasedInThisServer = true 
							task.spawn(function()
							    sendDiscordWebhook(cleanName, finalPurchaseQuantity, actualCost, totalRapValue, currentAssetId)
							end)
						end
					end
				end

			end
		end
	end
end

