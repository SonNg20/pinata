    end
end)
 
-- Toggle ON/OFF
btn.MouseButton1Click:Connect(function()
    enabled = not enabled
    if enabled then
        btn.BackgroundColor3 = Color3.fromRGB(0, 180, 80)
        btn.Text = "🟢 SNIPER ON"
    else
        btn.BackgroundColor3 = Color3.fromRGB(180, 50, 50)
        btn.Text = "🔴 SNIPER OFF"
    end
end)
