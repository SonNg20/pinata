local function parseConfigNumber(val)
    if type(val) == "number" then return val end
    if not val or val == "" then return 0 end
    local clean = string.lower(tostring(val)):gsub("%s+", ""):gsub("[^%d%.kmbt]", "")
    local num = tonumber(clean:match("[%d%.]+"))
    if not num then return 0 end
    local multiplier = 1
    if clean:find("k") then multiplier = 10^3
    elseif clean:find("m") then multiplier = 10^6
    elseif clean:find("b") then multiplier = 10^9 
    elseif clean:find("t") then multiplier = 10^12 end
    return math.floor(num * multiplier)
end

local function parsePercent(val)
    if type(val) == "number" then return val end
    if not val then return 0 end
    return tonumber((tostring(val):gsub("%%", ""))) or 0
end

