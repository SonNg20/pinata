local function detectDetailsFromUIFrame(itemSlot)
	if not itemSlot then return "Unknown", "Unknown" end
	local bg = itemSlot:FindFirstChild("Background") or itemSlot:FindFirstChild("Bg") or itemSlot:FindFirstChild("Frame")
	local predictedClass = "Unknown"
	if itemSlot:FindFirstChild("Points") or itemSlot:FindFirstChild("ShinePulse") or itemSlot:FindFirstChild("Glow") then predictedClass = "Pet"
	elseif itemSlot.Parent and itemSlot.Parent.Name:lower():find("pet") then predictedClass = "Pet"
	elseif itemSlot.Parent and (itemSlot.Parent.Name:lower():find("enchant") or itemSlot.Parent.Name:lower():find("book")) then predictedClass = "Enchant"
	elseif itemSlot.Parent and itemSlot.Parent.Name:lower():find("potion") then predictedClass = "Potion"
	elseif itemSlot.Parent and itemSlot.Parent.Name:lower():find("charm") then predictedClass = "Charm"
	elseif itemSlot.Parent and (itemSlot.Parent.Name:lower():find("misc") or itemSlot.Parent.Name:lower():find("item")) then predictedClass = "Misc"
	elseif itemSlot.Parent and itemSlot.Parent.Name:lower():find("lootbox") then predictedClass = "Lootbox"
	elseif itemSlot.Parent and itemSlot.Parent.Name:lower():find("booth") then predictedClass = "Booth"
	elseif itemSlot.Parent and itemSlot.Parent.Name:lower():find("fruit") then predictedClass = "Fruit"
	elseif itemSlot.Parent and itemSlot.Parent.Name:lower():find("egg") then predictedClass = "Egg"
	elseif itemSlot.Parent and itemSlot.Parent.Name:lower():find("ultimate") then predictedClass = "Ultimate" end

	if bg and bg:IsA("ImageLabel") then
		local bgImageId = tostring(bg.Image):match("%d+")
		if bgImageId then
			if bgImageId == "14300483868" or bgImageId == "16130424504" then return "Exclusive", (predictedClass ~= "Unknown" and predictedClass or "Pet")
			elseif bgImageId == "14300483101" then return "Celestial", (predictedClass == "Pet" and "Pet" or "Enchant")
			elseif bgImageId == "14300482312" then return "Mythical", (predictedClass ~= "Unknown" and predictedClass or "Item")
			elseif bgImageId == "14300481827" then return "Legendary", (predictedClass ~= "Unknown" and predictedClass or "Item")
			elseif bgImageId == "14300481287" then return "Epic", (predictedClass ~= "Unknown" and predictedClass or "Item")
			elseif bgImageId == "14300480315" then return "Rare", (predictedClass ~= "Unknown" and predictedClass or "Item")
			elseif bgImageId == "14300479701" then return "Basic", (predictedClass ~= "Unknown" and predictedClass or "Item") end
			return "Asset_" .. bgImageId, (predictedClass == "Pet" and "Pet" or predictedClass)
		end
	end
	return "Unknown", predictedClass
end

local function findItemDetailsInDirectory(imageString)
	if not imageString or imageString == "" then return nil, nil, nil end
	local assetId = imageString:match("%d+")
	if not assetId then return nil, nil, nil end
	if ImageCache[assetId] then return ImageCache[assetId].name, ImageCache[assetId].class, ImageCache[assetId].rarity end
	
	local blacklistedCategories = { ["DropTables"] = true, ["DropTable"] = true, ["ConveyorEvent"] = true, ["Lootbags"] = true }
	for categoryName, categoryTable in pairs(Directory) do
		if not blacklistedCategories[categoryName] and type(categoryTable) == "table" then
			for itemId, itemInfo in pairs(categoryTable) do
				if type(itemInfo) == "table" then
					local finalName, finalClass, finalRarity = nil, nil, nil
					pcall(function()
						local iconProp = itemInfo.Icon or itemInfo.icon or itemInfo.Thumbnail or itemInfo.thumbnail or itemInfo.ClassicIcon
						if iconProp and tostring(iconProp):find(assetId) then
							local rarity = itemInfo.Rarity or itemInfo.rarity
							if categoryName == "Pets" then
								if tostring(itemId):lower():find("huge") then rarity = "Huge"
								elseif tostring(itemId):lower():find("titanic") then rarity = "Titanic"
								else rarity = rarity or "Normal" end
							end
							finalName = itemInfo.Name or itemInfo.name or itemId
							finalClass = categoryName
							finalRarity = parseRarityName(rarity)
						end
					end)
					if finalName then
						ImageCache[assetId] = {name = finalName, class = finalClass, rarity = finalRarity}
						return finalName, finalClass, finalRarity 
					end
				end
			end
		end
	end
	return nil, nil, nil
end

local function extractDetailsFromAttribute(itemObj)
	local rawData = itemObj:GetAttribute("Data") or itemObj:GetAttribute("ItemData") or itemObj:GetAttribute("Item")
	if rawData then
		local decoded = type(rawData) == "string" and Library.JSONDecode(rawData) or rawData
		if decoded then
			local info = decoded.ItemData or decoded
			if info then
				local dataEntry = info.data or info
				if type(dataEntry) == "table" then
					local rawId = dataEntry.id or dataEntry._id or info.id or info._id
					local rawClass = info.class or info.Class or dataEntry.class or dataEntry.Class
					local rawRarity = dataEntry.rarity or info.rarity or dataEntry.Rarity or info.Rarity
					local parsedRarity = parseRarityName(rawRarity)
					local isGold = dataEntry.pt or dataEntry.gold or false
					if rawClass then return tostring(rawId or "Unknown Item"), tostring(rawClass), tostring(parsedRarity or "Unknown"), isGold end
				end
			end
		end
	end
	return nil, nil, nil, nil
end

local function parseShortenedNumber(text)
	if not text or text == "" then return 0 end
	local cleanText = string.lower(text):gsub("%s+", ""):gsub("[^%d%.kmbt]", "")
	local number = tonumber(cleanText:match("[%d%.]+"))
	if not number then return 0 end
	local multiplier = 1
	if cleanText:find("k") then multiplier = 10^3
	elseif cleanText:find("m") then multiplier = 10^6
	elseif cleanText:find("b") then multiplier = 10^9 
	elseif cleanText:find("t") then multiplier = 10^12 end
	return math.floor(number * multiplier)
end

