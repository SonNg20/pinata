local Network = game:GetService("ReplicatedStorage"):WaitForChild("Network")
local buyRemote = Network:WaitForChild("Booths_RequestPurchase")
local broadcastRemote = Network:WaitForChild("Booths_Broadcast")
local player = game:GetService("Players").LocalPlayer

local WHITELIST = {
    ["Watermelon"] = 500000,
    ["Royalty"] = 0,
}

local function getDiamonds()
    local ok, val = pcall(function() return player.leaderstats["💎 Diamonds"].Value end)
    return ok and val or 0
end

local bought = {}
local enabled = true
local traceStr = "ReplicatedStorage.Library.Client.BoothCmds:527 function PromptPurchase2" .. "\n" .. "ReplicatedStorage.Library.Client.BoothCmds:654 function promptOtherPlayerBooth2" .. "\n" .. "ReplicatedStorage.Library.Client.BoothCmds:157"
local function buyItem(playerID, uid, price, amount)
    if bought[uid] then return end
    bought[uid] = true
    local gems = getDiamonds()
    if price <= 0 or gems <= 0 then bought[uid] = nil return end
    local qty = math.min(amount, math.floor(gems / price))
    if qty <= 0 then bought[uid] = nil return end
    local ok = pcall(function()
        buyRemote:InvokeServer(playerID, {[uid] = qty}, {["Caller"] = {["LineNumber"] = 527, ["ParameterCount"] = 2, ["Variadic"] = false, ["Traceback"] = traceStr, ["ScriptPath"] = "ReplicatedStorage.Library.Client.BoothCmds", ["ScriptClass"] = "ModuleScript", ["Handle"] = "function: 0xa61d5c10646ed00d", ["FunctionName"] = "PromptPurchase2", ["ScriptType"] = "Instance", ["SourceIdentifier"] = "ReplicatedStorage.Library.Client.BoothCmds"}})
    end)
task.spawn(function()
    task.wait(2)
    broadcastRemote.OnClientEvent:Connect(function(...)
        if not enabled then return end
        local data = nil
        for _, v in ipairs({...}) do
            if type(v) == "table" and v.Listings then data = v break end
        end
        if not data or not data.Listings or not data.PlayerID then return end
        for uid, item in pairs(data.Listings) do
            if type(item) ~= "table" then continue end
            local price = item.DiamondCost
            local idata = item.ItemData
            if not price or not idata then continue end
            local name = idata.data and idata.data.id
            local amt = idata.data and idata.data._am or 1
            if not name then continue end
            if WHITELIST[name] ~= nil then
                local mp = WHITELIST[name]
                if mp == 0 or price <= mp then
                    task.spawn(buyItem, data.PlayerID, uid, price, amt)
                end
            end
        end
    end)
end)
