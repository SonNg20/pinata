local function obliterateVisualUI(v)
    if v:IsA("Frame") or v:IsA("TextLabel") or v:IsA("ImageLabel") 
    or v:IsA("TextButton") or v:IsA("ImageButton") or v:IsA("ScrollingFrame")
    or v:IsA("BillboardGui") or v:IsA("SurfaceGui") then
        
        local guiParent = v:FindFirstAncestorOfClass("ScreenGui")
        if guiParent and (
           guiParent.Name == "CoordinateTrackerGui" or 
           guiParent.Name == "BackroomsGridTracker" or 
           guiParent.Name == "BackroomsUiToggleGui" or 
           guiParent.Name == "SimpleAutoClickGui" or 
           guiParent.Name == "BackroomsFixUiGui" or 
           guiParent.Name == "BackroomsPureUiGui") then
            return
        end
        v:Destroy()
    end
end

for _, v in ipairs(PlayerGui:GetDescendants()) do pcall(obliterateVisualUI, v) end
PlayerGui.DescendantAdded:Connect(function(v) task.wait() pcall(obliterateVisualUI, v) end)

