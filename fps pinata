-- Khóa FPS về mức 7 ngay lập tức để tối ưu phần cứng cực hạn khi treo máy
if setfpscap then
    setfpscap(7)
end

repeat task.wait() until game:IsLoaded()

local Players = game:GetService("Players")
local StarterGui = game:GetService("StarterGui")
local LocalPlayer = Players.LocalPlayer
local PlayerGui = LocalPlayer:WaitForChild("PlayerGui")

task.wait(10)

-- Bộ lưu trữ danh sách các kết nối sự kiện để dọn dẹp RAM (Chống Memory Leak)
local PlayerConnections = {}

-- ========================================================
-- CẤU HÌNH ĐIỀU KIỆN LỌC (GIỮ PLAYER & LỌC BREAKABLES/PETS)
-- ========================================================
local function isPlayerBody(v)
    local current = v.Parent
    while current and current ~= game do
        if current:IsA("Model") and Players:GetPlayerFromCharacter(current) then return true end
        current = current.Parent
    end
    return false
end

local function isBreakableOrPetMesh(v)
    local name = v.Name
    if string.find(name, "Breakable") or string.find(name, "Pet") then return true end
    local current = v.Parent
    while current and current ~= game do
        local currName = current.Name
        if string.find(currName, "Breakable") or string.find(currName, "Pet") then return true end
        current = current.Parent
    end
    return false
end

-- ========================================================
-- HÀM TẮT ANIMATION CỦA PLAYER
-- ========================================================
local function disableCharacterAnimations(character)
    if not character then return end
    
    local animateScript = character:WaitForChild("Animate", 3) -- Giảm timeout xuống để giải phóng RAM nhanh
    if animateScript then animateScript.Enabled = false end
    
    local humanoid = character:WaitForChild("Humanoid", 3)
    if humanoid then
        local animator = humanoid:FindFirstChildOfClass("Animator")
        if animator then
            for _, track in ipairs(animator:GetPlayingAnimationTracks()) do
                track:Stop(0)
            end
            animator.AnimationPlayed:Connect(function(track)
                track:Stop(0)
            end)
        end
    end
end

-- Hàm quản lý kết nối an toàn cho Player (Tự hủy khi Player rời game để giải phóng RAM)
local function trackPlayer(player)
    if player == LocalPlayer then
        if player.Character then disableCharacterAnimations(player.Character) end
        player.CharacterAdded:Connect(disableCharacterAnimations)
        return
    end

    local conn = player.CharacterAdded:Connect(disableCharacterAnimations)
    PlayerConnections[player] = conn
    if player.Character then disableCharacterAnimations(player.Character) end
end

for _, p in ipairs(Players:GetPlayers()) do trackPlayer(p) end
Players.PlayerAdded:Connect(trackPlayer)

-- GIẢI PHÓNG RAM: Khi người chơi khác thoát, xóa sạch kết nối của họ khỏi bộ nhớ đệm Lua
Players.PlayerRemoving:Connect(function(player)
    if PlayerConnections[player] then
        PlayerConnections[player]:Disconnect()
        PlayerConnections[player] = nil
    end
end)

-- ========================================================
-- HÀM XỬ LÝ ĐỒ HỌA TỐI ƯU RAM (HÒM XÁM - TÀNG HÌNH PET)
-- ========================================================
local function processObjectFPS(v)
    if not v:IsA("BasePart") then return end
    
    if isBreakableOrPetMesh(v) then
        if string.find(v.Name, "Pet") or (v.Parent and string.find(v.Parent.Name, "Pet")) then
            v.Transparency = 1
            v.CanCollide = false
        else
            v.Shape = Enum.PartType.Block
            v.Size = Vector3.new(1.5, 1.5, 1.5)
            v.Color = Color3.fromRGB(128, 128, 128)
            v.Material = Enum.Material.SmoothPlastic
            v.CastShadow = false
        end
        
        -- Dọn dẹp hiệu ứng trong hòm
        for _, child in ipairs(v:GetChildren()) do
            if child:IsA("ParticleEmitter") or child:IsA("Trail") or child:IsA("Smoke") 
            or child:IsA("Fire") or child:IsA("Beam") or child:IsA("PointLight") 
            or child:IsA("SpotLight") or child:IsA("SurfaceLight") or child:IsA("SpecialMesh") 
            or child:IsA("BlockMesh") then
                child:Destroy()
            end
        end
    end
end

local function handleMapPart(v)
    if not v:IsA("BasePart") then return end
    if isPlayerBody(v) then return end
    
    if isBreakableOrPetMesh(v) then 
        processObjectFPS(v)
    else 
        v.Transparency = 1
    end
end

-- TỐI ƯU PHẠM VI QUÉT: Thay vì quét toàn bộ game, chỉ quét các vật thể trong Workspace
for _, v in ipairs(workspace:GetDescendants()) do 
    pcall(handleMapPart, v) 
end

-- Thay vì game.DescendantAdded, ta chỉ thu hẹp phạm vi nghe sự kiện ở workspace để tiết kiệm RAM
workspace.DescendantAdded:Connect(function(v)
    pcall(handleMapPart, v)
end)

-- ========================================================
-- HÀM DIỆT HIỆU ỨNG TRONG WORKSPACE (RÚT GỌN PHẠM VI QUÉT)
-- ========================================================
local function removeAllEffects(obj)
    if isPlayerBody(obj) then return end
    
    if obj:IsA("ParticleEmitter") or obj:IsA("Trail") or obj:IsA("Smoke") 
    or obj:IsA("Fire") or obj:IsA("Beam") or obj:IsA("PointLight") 
    or obj:IsA("SpotLight") or obj:IsA("SurfaceLight") then
        obj:Destroy()
    elseif obj:IsA("PostEffect") then
        obj.Enabled = false
    end
end

for _, v in ipairs(workspace:GetDescendants()) do pcall(removeAllEffects, v) end

-- ========================================================
-- PHẦN UI - BẢO VỆ XOAY CAMERA AN TOÀN
-- ========================================================
pcall(function() StarterGui:SetCoreGuiEnabled(Enum.CoreGuiType.All, false) end)

local function obliterateVisualUI(v)
    if v:IsA("Frame") or v:IsA("TextLabel") or v:IsA("ImageLabel") 
    or v:IsA("TextButton") or v:IsA("ImageButton") or v:IsA("ScrollingFrame")
    or v:IsA("BillboardGui") or v:IsA("SurfaceGui") then
        
        local guiParent = v:FindFirstAncestorOfClass("ScreenGui")
        if guiParent and (
           guiParent.Name == "CoordinateTrackerGui" or 
           guiParent.Name == "BackroomsGridTracker" or 
           guiParent.Name == "BackroomsUiToggleGui" or 
           guiParent.Name == "SimpleAutoClickGui" or 
           guiParent.Name == "BackroomsFixUiGui" or 
           guiParent.Name == "BackroomsPureUiGui") then
            return
        end
        v:Destroy()
    end
end

for _, v in ipairs(PlayerGui:GetDescendants()) do pcall(obliterateVisualUI, v) end
PlayerGui.DescendantAdded:Connect(function(v) task.wait() pcall(obliterateVisualUI, v) end)

local camera = workspace.CurrentCamera
if camera then
    for _, child in ipairs(camera:GetChildren()) do
        if child:IsA("Model") or child:IsA("BasePart") then child:Destroy() end
    end
    camera.ChildAdded:Connect(function(child)
        if child:IsA("Model") or child:IsA("BasePart") then task.wait() child:Destroy() end
    end)
end
