repeat task.wait() until game:IsLoaded()

local Players = game:GetService("Players")
local Lighting = game:GetService("Lighting")
local Workspace = game:GetService("Workspace")
local Terrain = Workspace:FindFirstChildOfClass("Terrain")

local LocalPlayer = Players.LocalPlayer

-- FPS CAP
pcall(function()
    setfpscap(60)
end)

-- LIGHTING
Lighting.GlobalShadows = false
Lighting.FogEnd = 9e9
Lighting.Brightness = 0
Lighting.Ambient = Color3.fromRGB(128,128,128)
Lighting.OutdoorAmbient = Color3.fromRGB(128,128,128)
Lighting.ColorShift_Top = Color3.new()
Lighting.ColorShift_Bottom = Color3.new()

pcall(function()
    settings().Rendering.QualityLevel = Enum.QualityLevel.Level01
end)

-- Đen trắng toàn game
pcall(function()
    local old = Lighting:FindFirstChild("FPSBOOST_CC")
    if old then
        old:Destroy()
    end

    local cc = Instance.new("ColorCorrectionEffect")
    cc.Name = "FPSBOOST_CC"
    cc.Saturation = -1
    cc.Contrast = 0
    cc.Brightness = 0
    cc.Parent = Lighting
end)

-- Tắt hiệu ứng Lighting
for _,v in ipairs(Lighting:GetChildren()) do
    if v:IsA("BlurEffect")
    or v:IsA("BloomEffect")
    or v:IsA("SunRaysEffect")
    or v:IsA("DepthOfFieldEffect")
    or v:IsA("ColorCorrectionEffect") then

        if v.Name ~= "FPSBOOST_CC" then
            v.Enabled = false
        end
    end
end

-- TERRAIN
if Terrain then
    Terrain.WaterWaveSize = 0
    Terrain.WaterWaveSpeed = 0
    Terrain.WaterReflectance = 0
    Terrain.WaterTransparency = 1
end

local function Optimize(v)

    -- Particle / Effects
    if v:IsA("ParticleEmitter")
    or v:IsA("Trail")
    or v:IsA("Smoke")
    or v:IsA("Fire")
    or v:IsA("Sparkles")
    or v:IsA("Beam") then

        pcall(function()
            v.Enabled = false
        end)
    end

    -- Highlight
    if v:IsA("Highlight") then
        pcall(function()
            v.Enabled = false
        end)
    end

    -- Lights
    if v:IsA("PointLight")
    or v:IsA("SpotLight")
    or v:IsA("SurfaceLight") then

        v.Enabled = false
    end

    -- Texture / Decal
    if v:IsA("Decal")
    or v:IsA("Texture") then

        v.Transparency = 1
    end

    -- BasePart
    if v:IsA("BasePart") then
        v.Material = Enum.Material.Plastic
        v.Reflectance = 0
        v.CastShadow = false
        v.Color = Color3.fromRGB(128,128,128)
    end

    -- MeshPart
    if v:IsA("MeshPart") then
        pcall(function()
            v.TextureID = ""
        end)
    end

    -- Chỉ tắt GUI 3D ngoài map
    if v:IsA("BillboardGui")
    or v:IsA("SurfaceGui") then

        pcall(function()
            v.Enabled = false
        end)
    end
end

-- Tối ưu object hiện có
for _,v in ipairs(game:GetDescendants()) do
    pcall(Optimize, v)
end

-- Tối ưu object mới spawn
game.DescendantAdded:Connect(function(v)
    pcall(Optimize, v)
end)

-- Anti AFK
pcall(function()
    local VirtualUser = game:GetService("VirtualUser")

    LocalPlayer.Idled:Connect(function()
        VirtualUser:CaptureController()
        VirtualUser:ClickButton2(Vector2.new())
    end)
end)

-- Nhảy 1 lần mỗi 300 giây
task.spawn(function()
    while true do
        task.wait(300)

        local character = LocalPlayer.Character
        local humanoid = character and character:FindFirstChildOfClass("Humanoid")

        if humanoid then
            humanoid.Jump = true
        end
    end
end)

print("FPS BOOST + ANTI AFK LOADED")
