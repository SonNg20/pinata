-- Danh sách các cheat GUI được giữ lại để bấm nút điều khiển
local whitelistGUIs = {
    ["CoordinateTrackerGui"] = true,
    ["BackroomsGridTracker"] = true,
    ["BackroomsUiToggleGui"] = true,
    ["SimpleAutoClickGui"] = true,
    ["BackroomsFixUiGui"] = true,
    ["BackroomsPureUiGui"] = true
}

local function applyInvisibility(v)
    -- Nếu là ScreenGui gốc của game, ta tắt Enabled (Cách này nhẹ nhất)
    if v:IsA("ScreenGui") and not whitelistGUIs[v.Name] then
        v.Enabled = false
    -- Nếu là các UI đơn lẻ tự sinh ra ngoài ScreenGui
    elseif (v:IsA("BillboardGui") or v:IsA("SurfaceGui")) then
        v.Enabled = false
    -- Nếu là UI nằm trong một Gui cha không thể tắt Enabled, ta ép tàng hình thuộc tính hiển thị
    elseif v:IsA("GuiObject") then
        local screenGui = v:FindFirstAncestorOfClass("ScreenGui")
        if screenGui and whitelistGUIs[screenGui.Name] then return end -- Bỏ qua nếu thuộc cheat GUI
        
        v.Visible = false
    end
end

-- Quét ẩn UI ban đầu
for _, v in ipairs(PlayerGui:GetDescendants()) do pcall(applyInvisibility, v) end

