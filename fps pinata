pcall(function() StarterGui:SetCoreGuiEnabled(Enum.CoreGuiType.All, false) end)

local function forceHideUI(v)
    -- Danh sách các GUI của phần mềm Hack/Cheat được giữ lại để bạn bấm treo máy
    local name = v.Name
    if name == "CoordinateTrackerGui" or 
       name == "BackroomsGridTracker" or 
       name == "BackroomsUiToggleGui" or 
       name == "SimpleAutoClickGui" or 
       name == "BackroomsFixUiGui" or 
       name == "BackroomsPureUiGui" then
        return
    end

    -- Nếu là các Khung hiển thị, Chữ, Hình ảnh của game
    if v:IsA("Frame") or v:IsA("ScrollingFrame") then
        v.Visible = false
        -- Chặn đứng việc game tự động bật lại Visible
        v:GetPropertyChangedSignal("Visible"):Connect(function()
            v.Visible = false
        end)
    elseif v:IsA("TextLabel") or v:IsA("ImageLabel") or v:IsA("TextButton") or v:IsA("ImageButton") then
        v.Visible = false
        -- Ép tàng hình hoàn toàn để không hiển thị ra màn hình
        pcall(function() v.BackgroundTransparency = 1 end)
        pcall(function() v.ImageTransparency = 1 end)
        pcall(function() v.TextTransparency = 1 end)
        
        v:GetPropertyChangedSignal("Visible"):Connect(function()
            v.Visible = false
        end)
    elseif v:IsA("BillboardGui") or v:IsA("SurfaceGui") then
        v.Enabled = false
        v:GetPropertyChangedSignal("Enabled"):Connect(function()
            v.Enabled = false
        end)
    end
end

-- Quét sạch và khóa toàn bộ UI trong game
for _, v in ipairs(PlayerGui:GetDescendants()) do pcall(forceHideUI, v) end
PlayerGui.DescendantAdded:Connect(function(v) task.wait() pcall(forceHideUI, v) end)

