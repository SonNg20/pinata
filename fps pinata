-- ========================================================
-- LUỒNG QUÉT ZONE (CẬP NHẬT TÂM VÒNG TRÒN LAZE BÁN KÍNH)
-- ========================================================
task.spawn(function()
    while true do
        pcall(function()
            local character = LocalPlayer.Character
            local rootPart = character and character:FindFirstChild("HumanoidRootPart")
            if not rootPart then 
                CurrentActiveZone = nil
                VisualRadiusPart.Adornee = nil
                return 
            end
            
            local playerPos = rootPart.Position
            local nearestZone = nil
            local minZoneDistance = math.huge
            
            for _, desc in ipairs(workspace:GetDescendants()) do
                if desc:IsA("BasePart") and desc.Name == "BREAK_ZONE" then
                    local dist = (desc.Position - playerPos).Magnitude
                    if dist <= 80 and dist < minZoneDistance then
                        minZoneDistance = dist
                        nearestZone = desc
                    end
                end
            end
            
            CurrentActiveZone = nearestZone
            
            if nearestZone then
                VisualRadiusPart.Adornee = nearestZone
                VisualRadiusPart.CFrame = CFrame.new(0, -nearestZone.Size.Y/2, 0) * CFrame.Angles(math.rad(90), 0, 0)
            else
                VisualRadiusPart.Adornee = nil
            end
        end)
        task.wait(1)
    end
end)

-- ========================================================
-- KHỞI TẠO ĐA LUỒNG HEARTBEAT CLICK LIÊN TỤC KHÔNG DELAY (RANGE 150)
-- ========================================================
for threadId = 1, 5 do
    task.spawn(function()
        RunService.Heartbeat:Connect(function()
            if CurrentActiveZone and BreakablesFolder then
                pcall(function()
                    local allBreakables = BreakablesFolder:GetChildren()
                    local zonePos = CurrentActiveZone.Position
                    local maxRange = 150
                    
                    local attacksInThisTurn = 0
                    
                    for i = threadId, #allBreakables, 5 do
                        local breakable = allBreakables[i]
                        if breakable then
                            local primaryPart = breakable:FindFirstChildOfClass("Part") or breakable:FindFirstChildOfClass("MeshPart")
                            
                            if primaryPart then
                                local offset = primaryPart.Position - zonePos
                                if math.abs(offset.X) <= maxRange and math.abs(offset.Z) <= maxRange then
                                    
                                    DamageRemote:FireServer(breakable.Name)
                                    attacksInThisTurn = attacksInThisTurn + 1
                                    
                                    if attacksInThisTurn >= 5 then
                                        break
                                    end
                                end
                            end
                        end
                    end
                end)
            end
        end)
    end)
end
