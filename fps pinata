repeat task.wait() until game:IsLoaded()
wait(5)

local Players = game:GetService("Players")

-- Hàm kiểm tra xem đối tượng có thuộc về Player hoặc Breakables hay không
local function isProtected(v)
    -- 1. Kiểm tra nếu thuộc hệ thống Breakables
    if string.find(v.Name, "Breakable") then
        return true
    end
    
    -- Quét ngược lên các đời cha (Parent) để kiểm tra Character hoặc Breakables
    local current = v.Parent
    while current and current ~= game do
        -- Kiểm tra thư mục chứa Breakable
        if string.find(current.Name, "Breakable") then
            return true
        end
        -- Kiểm tra nếu đối tượng nằm trong Character của một Player bất kỳ
        if current:IsA("Model") and Players:GetPlayerFromCharacter(current) then
            return true
        end
        current = current.Parent
    end
    
    return false
end

-- QUÉT WORKSPACE HIỆN TẠI
for _, v in next, workspace:GetDescendants() do
    pcall(function()
        if v:IsA("BasePart") then
            -- Chỉ ẩn nếu KHÔNG thuộc diện bảo vệ (Breakables, Pet, Player)
            if not isProtected(v) then
                v.Transparency = 1
            end
        end
    end)
end

-- QUÉT NIL INSTANCES (Các object bị ẩn trong bộ nhớ)
for _, v in next, getnilinstances() do
    pcall(function()
        if v:IsA("BasePart") then
            if not isProtected(v) then
                v.Transparency = 1
            end
        end

        for _, v1 in next, v:GetDescendants() do
            if v1:IsA("BasePart") then
                if not isProtected(v1) then
                    v1.Transparency = 1
                end
            end
        end
    end)
end

-- XỬ LÝ ĐỐI TƯỢNG MỚI SPAWN RA MAP
workspace.DescendantAdded:Connect(function(v)
    pcall(function()
        if v:IsA("BasePart") then
            if not isProtected(v) then
                v.Transparency = 1
            end
        end
    end)
end)

-- XÓA CÁC HIỆU ỨNG RÁC GÂY LAG (Hạt, ánh sáng, khói lửa...)
local function removeEffects(obj)
    -- Chỉ xóa hiệu ứng nếu nó KHÔNG thuộc diện bảo vệ
    if not isProtected(obj) then
        if obj:IsA("ParticleEmitter")
        or obj:IsA("Trail")
        or obj:IsA("Smoke")
        or obj:IsA("Fire")
        or obj:IsA("Beam") then
            obj:Destroy()
        end

        if obj:IsA("PointLight")
        or obj:IsA("SpotLight")
        or obj:IsA("SurfaceLight") then
            obj:Destroy()
        end

        if obj:IsA("PostEffect") then
            obj.Enabled = false
        end
    end
end

-- Chạy xóa hiệu ứng nền
for _, v in ipairs(game:GetDescendants()) do
    removeEffects(v)
end
game.DescendantAdded:Connect(removeEffects)

print("⚡ OPTIMIZED FPS BOOST: GIỮ LẠI PLAYER, BREAKABLES & PET MESH ⚡")
