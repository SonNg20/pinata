repeat task.wait() until game:IsLoaded()
wait(15)

-- Hàm kiểm tra xem đối tượng có thuộc hệ thống Breakables hay không
local function isBreakableOrPetMesh(v)
    -- Kiểm tra nếu tên đối tượng hoặc tên các thư mục cha có chứa chữ "Breakable" hoặc "Breakables"
    if string.find(v.Name, "Breakable") then
        return true
    end
    
    -- Quét ngược lên các đời cha (Parent) để đảm bảo không ẩn nhầm Pet.Mesh nằm sâu bên trong
    local current = v.Parent
    while current and current ~= game do
        if string.find(current.Name, "Breakable") then
            return true
        end
        current = current.Parent
    end
    
    return false
end

-- QUÉT WORKSPACE HIỆN TẠI
for _, v in next, workspace:GetDescendants() do
    pcall(function()
        if v:IsA("BasePart") then
            -- Chỉ ẩn nếu KHÔNG thuộc hệ thống Breakables
            if not isBreakableOrPetMesh(v) then
                v.Transparency = 1
            end
        end
    end)
end

-- QUÉT NIL INSTANCES (Các object bị ẩn trong bộ nhớ)
for _, v in next, getnilinstances() do
    pcall(function()
        if v:IsA("BasePart") then
            if not isBreakableOrPetMesh(v) then
                v.Transparency = 1
            end
        end

        for _, v1 in next, v:GetDescendants() do
            if v1:IsA("BasePart") then
                if not isBreakableOrPetMesh(v1) then
                    v1.Transparency = 1
                end
            end
        end
    end)
end

-- XỬ LÝ ĐỐI TƯỢNG MỚI SPAWN RA MAP
workspace.DescendantAdded:Connect(function(v)
    pcall(function()
        if v:IsA("BasePart") then
            if not isBreakableOrPetMesh(v) then
                v.Transparency = 1
            end
        end
    end)
end)

-- XÓA CÁC HIỆU ỨNG RÁC GÂY LAG (Hạt, ánh sáng, khói lửa...)
local function removeEffects(obj)
    -- Chỉ xóa hiệu ứng nếu nó KHÔNG nằm trong thư mục Breakables (tránh lỗi hiển thị của game)
    if not isBreakableOrPetMesh(obj) then
        if obj:IsA("ParticleEmitter")
        or obj:IsA("Trail")
        or obj:IsA("Smoke")
        or obj:IsA("Fire")
        or obj:IsA("Beam") then
            obj:Destroy()
        end

        if obj:IsA("PointLight")
        or obj:IsA("SpotLight")
        or obj:IsA("SurfaceLight") then
            obj:Destroy()
        end

        if obj:IsA("PostEffect") then
            obj.Enabled = false
        end
    end
end

-- Chạy xóa hiệu ứng nền
for _, v in ipairs(game:GetDescendants()) do
    removeEffects(v)
end
game.DescendantAdded:Connect(removeEffects)

print("⚡ OPTIMIZED FPS BOOST: GIỮ LẠI BREAKABLES & PET MESH ⚡")
