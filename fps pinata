-- Định nghĩa tài nguyên cho phần Auto Damage
local DamageRemote = ReplicatedStorage:WaitForChild("Network"):WaitForChild("Breakables_PlayerDealDamage")
local BreakablesFolder = workspace:FindFirstChild("__THINGS") and workspace.__THINGS:FindFirstChild("Breakables")
local CurrentActiveZone = nil

-- Khởi tạo vòng tròn hiển thị bán kính laze trực quan (150 studs - màu xám)
local VisualRadiusPart = Instance.new("CylinderHandleAdornment")
VisualRadiusPart.Name = "FarmRadiusVisual"
VisualRadiusPart.Color3 = Color3.fromRGB(128, 128, 128)
VisualRadiusPart.Transparency = 0.8
VisualRadiusPart.Radius = 150
VisualRadiusPart.Height = 1
VisualRadiusPart.Angle = 360
VisualRadiusPart.Adornee = nil
VisualRadiusPart.Parent = workspace.CurrentCamera

-- ========================================================
-- CẤU HÌNH ĐIỀU KIỆN LỌC (GIỮ PLAYER & LỌC BREAKABLES)
-- ========================================================
local function isPlayerBody(v)
    local current = v.Parent
    while current and current ~= game do
        if current:IsA("Model") and Players:GetPlayerFromCharacter(current) then return true end
        current = current.Parent
    end
    return false
end

local function isBreakableOrPetMesh(v)
    if string.find(v.Name, "Breakable") then return true end
    local current = v.Parent
    while current and current ~= game do
        if string.find(current.Name, "Breakable") then return true end
        current = current.Parent
    end
    return false
end

-- ========================================================
-- HÀM BIẾN BREAKABLE THÀNH KHỐI VUÔNG NHỎ MÀU XÁM (XÓA MÀU GỐC)
-- ========================================================
local function boxifyBreakable(v)
    pcall(function()
        if v:IsA("BasePart") and isBreakableOrPetMesh(v) and not string.find(v.Name, "Pet") then
            v.Shape = Enum.PartType.Block
            v.Size = Vector3.new(1.5, 1.5, 1.5)
            v.Color = Color3.fromRGB(128, 128, 128)
            v.Material = Enum.Material.SmoothPlastic
            v.CastShadow = false
            
            for _, child in ipairs(v:GetChildren()) do
                if child:IsA("ParticleEmitter") or child:IsA("Trail") or child:IsA("Smoke") 
                or child:IsA("Fire") or child:IsA("Beam") or child:IsA("PointLight") 
                or child:IsA("SpotLight") or child:IsA("SurfaceLight") or child:IsA("SpecialMesh") 
                or child:IsA("BlockMesh") then
                    child:Destroy()
                end
            end
        end
    end)
end

-- Quét ẩn bức tường map nền và thực hiện ép hộp xóa màu hòm
local function handleMapPart(v)
    pcall(function()
        if v:IsA("BasePart") then
            if isPlayerBody(v) then 
                -- Giữ nguyên nhân vật của bạn
            elseif isBreakableOrPetMesh(v) then 
                boxifyBreakable(v)
            else 
                v.Transparency = 1
            end
        end
    end)
end

for _, v in next, workspace:GetDescendants() do handleMapPart(v) end
workspace.DescendantAdded:Connect(handleMapPart)

-- Diệt toàn bộ các hiệu ứng môi trường lơ lửng gây nặng máy
local function removeAllEffects(obj)
    if not isPlayerBody(obj) then
        if obj:IsA("ParticleEmitter") or obj:IsA("Trail") or obj:IsA("Smoke") 
        or obj:IsA("Fire") or obj:IsA("Beam") or obj:IsA("PointLight") 
        or obj:IsA("SpotLight") or obj:IsA("SurfaceLight") then
            obj:Destroy()
        end
        if obj:IsA("PostEffect") then
            obj.Enabled = false
        end
    end
end
for _, v in ipairs(game:GetDescendants()) do pcall(removeAllEffects, v) end
game.DescendantAdded:Connect(function(v) pcall(removeAllEffects, v) end)

