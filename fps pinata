-- Khóa FPS về mức 7 ngay lập tức để tối ưu phần cứng cực hạn khi treo máy
if setfpscap then
    setfpscap(7)
end

repeat task.wait() until game:IsLoaded()

local Players = game:GetService("Players")
local StarterGui = game:GetService("StarterGui")
local LocalPlayer = Players.LocalPlayer
local PlayerGui = LocalPlayer:WaitForChild("PlayerGui")

task.wait(10)

-- ========================================================
-- CẤU HÌNH ĐIỀU KIỆN LỌC (GIỮ PLAYER & LỌC BREAKABLES/PETS)
-- ========================================================
local function isPlayerBody(v)
    local current = v.Parent
    while current and current ~= game do
        if current:IsA("Model") and Players:GetPlayerFromCharacter(current) then return true end
        current = current.Parent
    end
    return false
end

local function isBreakableOrPetMesh(v)
    if string.find(v.Name, "Breakable") or string.find(v.Name, "Pet") then return true end
    local current = v.Parent
    while current and current ~= game do
        if string.find(current.Name, "Breakable") or string.find(current.Name, "Pet") then return true end
        current = current.Parent
    end
    return false
end

-- ========================================================
-- HÀM TẮT ANIMATION CỦA TẤT CẢ PLAYER (BẢO GỒM BẢN THÂN VÀ NGƯỜI KHÁC)
-- ========================================================
local function disableCharacterAnimations(character)
    if not character then return end
    
    -- 1. Tắt script điều khiển hoạt ảnh mặc định Animate
    local animateScript = character:WaitForChild("Animate", 5)
    if animateScript then
        animateScript.Enabled = false
    end
    
    -- 2. Tìm Humanoid và chặn đứng các Track hoạt ảnh đang/sẽ chạy
    local humanoid = character:WaitForChild("Humanoid", 5)
    if humanoid then
        local animator = humanoid:FindFirstChildOfClass("Animator")
        if animator then
            -- Dừng các hoạt ảnh đang chạy sẵn
            for _, track in ipairs(animator:GetPlayingAnimationTracks()) do
                track:Stop(0)
            end
            -- Đóng băng ngay lập tức nếu phát hiện nạp hoạt ảnh mới
            animator.AnimationPlayed:Connect(function(track)
                track:Stop(0)
            end)
        end
    end
end

-- Quét và áp dụng cho những người chơi đang có sẵn trong Server
for _, player in ipairs(Players:GetPlayers()) do
    if player.Character then
        disableCharacterAnimations(player.Character)
    end
    -- Theo dõi nếu họ bị chết hoặc đổi nhân vật mới (Respawn)
    player.CharacterAdded:Connect(disableCharacterAnimations)
end

-- Theo dõi những người chơi mới vừa mới bấm vào tham gia Server (Join Game)
Players.PlayerAdded:Connect(function(player)
    player.CharacterAdded:Connect(disableCharacterAnimations)
end)

-- ========================================================
-- HÀM XỬ LÝ ĐỒ HỌA: HÒM THÀNH KHỐI XÁM - DIỆT SẠCH MESH CỦA PET
-- ========================================================
local function processObjectFPS(v)
    pcall(function()
        if v:IsA("BasePart") and isBreakableOrPetMesh(v) then
            if string.find(v.Name, "Pet") or (v.Parent and string.find(v.Parent.Name, "Pet")) then
                v.Transparency = 1
                v.CanCollide = false
            else
                v.Shape = Enum.PartType.Block
                v.Size = Vector3.new(1.5, 1.5, 1.5)
                v.Color = Color3.fromRGB(128, 128, 128)
                v.Material = Enum.Material.SmoothPlastic
                v.CastShadow = false
            end
            
            for _, child in ipairs(v:GetChildren()) do
                if child:IsA("ParticleEmitter") or child:IsA("Trail") or child:IsA("Smoke") 
                or child:IsA("Fire") or child:IsA("Beam") or child:IsA("PointLight") 
                or child:IsA("SpotLight") or child:IsA("SurfaceLight") or child:IsA("SpecialMesh") 
                or child:IsA("BlockMesh") then
                    child:Destroy()
                end
            end
        end
    end)
end

local function handleMapPart(v)
    pcall(function()
        if v:IsA("BasePart") then
            if isPlayerBody(v) then 
                -- Giữ nguyên hình thể người để ko bị mất xác (hoạt ảnh đã đóng băng ở trên)
            elseif isBreakableOrPetMesh(v) then 
                processObjectFPS(v)
            else 
                v.Transparency = 1
            end
        end
    end)
end

for _, v in next, workspace:GetDescendants() do handleMapPart(v) end
workspace.DescendantAdded:Connect(handleMapPart)

-- Diệt toàn bộ các hiệu ứng môi trường lơ lửng gây nặng máy
local function removeAllEffects(obj)
    if not isPlayerBody(obj) then
        if obj:IsA("ParticleEmitter") or obj:IsA("Trail") or obj:IsA("Smoke") 
        or obj:IsA("Fire") or obj:IsA("Beam") or obj:IsA("PointLight") 
        or obj:IsA("SpotLight") or obj:IsA("SurfaceLight") then
            obj:Destroy()
        end
        if obj:IsA("PostEffect") then
            obj.Enabled = false
        end
    end
end
for _, v in ipairs(game:GetDescendants()) do pcall(removeAllEffects, v) end
game.DescendantAdded:Connect(function(v) pcall(removeAllEffects, v) end)

-- ========================================================
-- PHẦN UI - BẢO VỆ XOAY CAMERA AN TOÀN
-- ========================================================
pcall(function()
    StarterGui:SetCoreGuiEnabled(Enum.CoreGuiType.All, false)
end)

local function obliterateVisualUI(v)
    if v:IsA("Frame") or v:IsA("TextLabel") or v:IsA("ImageLabel") 
    or v:IsA("TextButton") or v:IsA("ImageButton") or v:IsA("ScrollingFrame")
    or v:IsA("BillboardGui") or v:IsA("SurfaceGui") then
        
        local guiParent = v:FindFirstAncestorOfClass("ScreenGui")
        if guiParent and (
           guiParent.Name == "CoordinateTrackerGui" or 
           guiParent.Name == "BackroomsGridTracker" or 
           guiParent.Name == "BackroomsUiToggleGui" or 
           guiParent.Name == "SimpleAutoClickGui" or 
           guiParent.Name == "BackroomsFixUiGui" or 
           guiParent.Name == "BackroomsPureUiGui") then
            return
        end
        v:Destroy()
    end
end

for _, v in ipairs(PlayerGui:GetDescendants()) do pcall(obliterateVisualUI, v) end
PlayerGui.DescendantAdded:Connect(function(v) task.wait() pcall(obliterateVisualUI, v) end)

local camera = workspace.CurrentCamera
if camera then
    for _, child in ipairs(camera:GetChildren()) do
        if child:IsA("Model") or child:IsA("BasePart") then child:Destroy() end
    end
    camera.ChildAdded:Connect(function(child)
        if child:IsA("Model") or child:IsA("BasePart") then task.wait() child:Destroy() end
    end)
end
