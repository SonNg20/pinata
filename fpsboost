-- ============================
-- ẨN PET MODEL TRONG PET SIMULATOR 99
-- ============================

-- Cấu trúc pet trong PS99 thường là Model chứa các part
-- Pet thường được spawn trong workspace hoặc trong player character

local function hidePet(petModel)
    if not petModel:IsA("Model") then return end
    
    -- Ẩn tất cả part bên trong pet
    for _, part in ipairs(petModel:GetDescendants()) do
        pcall(function()
            if part:IsA("BasePart") then
                part.Transparency = 1
                part.CanCollide = false
                part.CastShadow = false
                if part:IsA("MeshPart") then
                    part.TextureID = ""
                end
            end
            -- Tắt effect trong pet
            if part:IsA("ParticleEmitter") or part:IsA("Trail") or part:IsA("Beam") 
                or part:IsA("Fire") or part:IsA("Smoke") or part:IsA("Sparkles") then
                part.Enabled = false
            end
            if part:IsA("Light") or part:IsA("PointLight") or part:IsA("SpotLight") then
                part.Enabled = false
            end
            if part:IsA("Decal") or part:IsA("Texture") then
                part.Transparency = 1
            end
            if part:IsA("BillboardGui") then
                part.Enabled = false
            end
            if part:IsA("Highlight") then
                part.Enabled = false
            end
        end)
    end
    
    -- Đổi tên để script khác không hiển thị lại
    pcall(function() petModel.Name = "_Hidden_Pet" end)
end

-- Quét tất cả pet hiện có
local function scanAndHidePets()
    -- Pet trong workspace
    for _, obj in ipairs(workspace:GetDescendants()) do
        pcall(function()
            if obj:IsA("Model") then
                local name = obj.Name
                local parent = obj.Parent
                local parentName = parent and parent.Name or ""
                
                -- Check các tên pet phổ biến trong PS99
                if string.find(name, "Pet") 
                    or string.find(name, "Huge") 
                    or string.find(name, "Titanic")
                    or string.find(name, "Exclusive")
                    or string.find(name, "Egg")
                    or string.find(name, "Companion")
                    or string.find(parentName, "Pet")
                    or string.find(parentName, "Pets") then
                    hidePet(obj)
                end
            end
        end)
    end
    
    -- Pet trong người chơi (thường trong folder "Pets")
    for _, player in ipairs(game:GetService("Players"):GetPlayers()) do
        if player.Character then
            local petsFolder = player.Character:FindFirstChild("Pets")
            if petsFolder then
                for _, pet in ipairs(petsFolder:GetChildren()) do
                    pcall(hidePet, pet)
                end
            end
        end
    end
end

-- Chạy lần đầu
scanAndHidePets()

-- Listener: khi pet mới spawn
workspace.DescendantAdded:Connect(function(v)
    pcall(function()
        if v:IsA("Model") then
            local name = v.Name
            local parent = v.Parent
            local parentName = parent and parent.Name or ""
            
            if string.find(name, "Pet") 
                or string.find(name, "Huge") 
                or string.find(name, "Titanic")
                or string.find(name, "Exclusive")
                or string.find(name, "Egg")
                or string.find(name, "Companion")
                or string.find(parentName, "Pet")
                or string.find(parentName, "Pets") then
                task.wait(0.1) -- Đợi pet load xong
                hidePet(v)
            end
        end
    end)
end)

-- Listener: khi player spawn pet mới
game:GetService("Players").PlayerAdded:Connect(function(player)
    player.CharacterAdded:Connect(function(char)
        local petsFolder = char:WaitForChild("Pets", 5)
        if petsFolder then
            -- Ẩn pet hiện có
            for _, pet in ipairs(petsFolder:GetChildren()) do
                pcall(hidePet, pet)
            end
            
            -- Theo dõi pet mới
            petsFolder.ChildAdded:Connect(function(pet)
                task.wait(0.1)
                pcall(hidePet, pet)
            end)
        end
    end)
end)

-- Định kỳ quét lại (phòng trường hợp bỏ sót)
task.spawn(function()
    while task.wait(10) do
        scanAndHidePets()
    end
end)
