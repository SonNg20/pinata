-- ========================================================
-- CẤU HÌNH ĐIỀU KIỆN LỌC
-- ========================================================
local function isProtected(obj)
    -- Bảo vệ Backrooms ClientModule và các object liên quan
    if obj.Name == "ClientModule" then return true end
    if obj:IsA("ModuleScript") then return true end
    if obj:IsA("Script") then return true end
    if obj:IsA("LocalScript") then return true end
    
    -- Bảo vệ Backrooms folder
    local parent = obj.Parent
    while parent do
        if parent.Name == "Backrooms" or parent.Name == "ClientModule" then
            return true
        end
        parent = parent.Parent
    end
    
    return false
end

local function isPlayerBody(v)
    if not LocalPlayer.Character then return false end
    return v:IsDescendantOf(LocalPlayer.Character) or Players:GetPlayerFromCharacter(v:FindFirstAncestorOfClass("Model")) ~= nil
end

local function isBreakable(v)
    if v:IsA("Model") and v:GetAttribute("BreakableUID") then return true end
    if v.Parent and v.Parent:IsA("Model") and v.Parent:GetAttribute("BreakableUID") then return true end
    return false
end

-- Diệt hiệu ứng (chừa Backrooms)
local function killEffectInstance(obj)
    if isPlayerBody(obj) then return end
    if isProtected(obj) then return end
    
    if obj:IsA("ParticleEmitter") or obj:IsA("Trail") or obj:IsA("Smoke") 
    or obj:IsA("Fire") or obj:IsA("Beam") or obj:IsA("PointLight") 
    or obj:IsA("SpotLight") or obj:IsA("SurfaceLight") then
        obj:Destroy()
    elseif obj:IsA("PostEffect") then
        obj.Enabled = false
    end
end

-- ========================================================
-- ẨN NGƯỜI CHƠI KHÁC
-- ========================================================
local function hideAndDisableCharacter(character)
    if not character or character == LocalPlayer.Character then return end
    
    local humanoid = character:FindFirstChild("Humanoid")
    if humanoid then
        humanoid.DisplayDistanceType = Enum.HumanoidDisplayDistanceType.None
        humanoid.HealthDisplayType = Enum.HumanoidHealthDisplayType.AlwaysOff
        
        local animator = humanoid:FindFirstChildOfClass("Animator")
        if animator then animator:Destroy() end
        Instance.new("Animator").Parent = humanoid
    end
    
    for _, obj in ipairs(character:GetDescendants()) do
        if obj:IsA("BasePart") or obj:IsA("Decal") then
            obj.Transparency = 1
            obj.CanCollide = false
        elseif obj:IsA("VisualAttachment") or obj:IsA("Attachment") then
            for _, child in ipairs(obj:GetChildren()) do killEffectInstance(child) end
        end
    end
end

for _, p in ipairs(Players:GetPlayers()) do
    if p ~= LocalPlayer and p.Character then hideAndDisableCharacter(p.Character) end
    p.CharacterAdded:Connect(hideAndDisableCharacter)
end
Players.PlayerAdded:Connect(function(p)
    p.CharacterAdded:Connect(hideAndDisableCharacter)
end)

-- ========================================================
-- TỐI ƯU HÓA WORKSPACE
-- ========================================================
local function handleMapPart(v)
    if isPlayerBody(v) then return end
    if isProtected(v) then return end
    
    -- Breakable: đơn điệu màu xám
    if isBreakable(v) then
        if v:IsA("BasePart") then
            v.Color = Color3.fromRGB(128, 128, 128)
            v.Material = Enum.Material.SmoothPlastic
            v.CastShadow = false
            if v:IsA("MeshPart") then v.TextureID = "" end
        end
        return
    end
    
    -- Map + Pet: ẩn
    if v:IsA("BasePart") then
        v.Transparency = 1
        v.CastShadow = false
        v.CanCollide = false
        if v:IsA("MeshPart") then v.TextureID = "" end
    elseif v:IsA("Texture") or v:IsA("Decal") or v:IsA("SpecialMesh") then
        v:Destroy()
    end
end

for _, v in ipairs(workspace:GetDescendants()) do 
    if not isProtected(v) then
        pcall(handleMapPart, v) 
        pcall(killEffectInstance, v)
    end
end
workspace.DescendantAdded:Connect(function(v)
    if not isProtected(v) then
        pcall(handleMapPart, v)
        pcall(killEffectInstance, v)
    end
end)

