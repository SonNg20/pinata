if not game:IsLoaded() then
    game.Loaded:Wait()
end
setfpscap(20)
local RunService = game:GetService("RunService")
local player = game.Players.LocalPlayer
local gui = Instance.new("ScreenGui", player:WaitForChild("PlayerGui"))

local label = Instance.new("TextLabel", gui)
label.Size = UDim2.new(0, 200, 0, 50)
label.Position = UDim2.new(0, 10, 0, 10)
label.BackgroundTransparency = 0.3
label.TextScaled = true
label.TextColor3 = Color3.new(1,1,1)

local frames = 0
local last = tick()

RunService.RenderStepped:Connect(function()
    frames += 1
    local now = tick()

    if now - last >= 1 then
        label.Text = "FPS: " .. frames
        frames = 0
        last = now
    end
end)

-- Hàm ẩn BasePart và Decal/Texture (Đặt Transparency = 1 thay vì hủy)
local function hideVisuals(v)
    pcall(function()
        if v:IsA("BasePart") then
            v.Transparency = 1
        elseif v:IsA("Decal") or v:IsA("Texture") then
            v.Transparency = 1
        end
    end)
end

-- Hàm tắt hiệu ứng (Đặt Enabled = false thay vì Destroy)
local function disableEffects(obj)
    pcall(function()
        if obj:IsA("ParticleEmitter")
        or obj:IsA("Trail")
        or obj:IsA("Smoke")
        or obj:IsA("Fire")
        or obj:IsA("Beam")
        or obj:IsA("PointLight")
        or obj:IsA("SpotLight")
        or obj:IsA("SurfaceLight") then
            obj.Enabled = false
        elseif obj:IsA("PostEffect") then
            obj.Enabled = false
        end
    end)
end

-- Quét toàn bộ map hiện tại
for _, v in ipairs(game:GetDescendants()) do
    hideVisuals(v)
    disableEffects(v)
end

-- Quét các đối tượng nil (lạc hướng)
for _, v in next, getnilinstances() do
    hideVisuals(v)
    pcall(function()
        for _, v1 in next, v:GetDescendants() do
            hideVisuals(v1)
        end
    end)
end

-- Lắng nghe các đối tượng mới sinh ra trong game để ẩn/tắt lập tức
game.DescendantAdded:Connect(function(v)
    hideVisuals(v)
    disableEffects(v)
end)
-- Vòng lặp xóa vật phẩm rơi (Loot/Dropped Items) và text để giảm lag
task.spawn(function()
    local Workspace = game:GetService("Workspace")
    
    while true do
        -- 1. Tìm và xóa các Model/Part của vật phẩm rơi trên map
        -- (Thường nằm trong 'Debris', 'DroppedItems', 'Loot' hoặc trực tiếp ngoài Workspace tùy phiên bản game)
        for _, obj in pairs(Workspace:GetChildren()) do
            if obj:IsA("Model") and (obj.Name:find("Diamond") or obj.Name:find("Flag") or obj.Name:find("Loot") or obj.Name:find("Item")) then
                obj:Destroy()
            end
        end
        
        -- Nếu game lưu vật phẩm trong thư mục Debris hoặc Thư mục riêng biệt
        if Workspace:FindFirstChild("Debris") then
            for _, obj in pairs(Workspace.Debris:GetChildren()) do
                obj:Destroy()
            end
        end

        -- 2. Xóa các bảng tên, thanh máu hoặc hiệu ứng chữ hiển thị trên sàn
        for _, v in pairs(Workspace:GetDescendants()) do
            if v:IsA("BillboardGui") or v:IsA("SurfaceGui") then
                v:Destroy()
            end
        end
        
        task.wait(1) -- Quét lại sau mỗi 1 giây
    end
end)
